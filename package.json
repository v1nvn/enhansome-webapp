{
  "name": "enhansome-webapp",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "serve": "vite preview",
    "test": "npm run test:integration && npm run test:ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test:ui:watch": "vitest --config vitest.ui.config.ts",
    "lint": "eslint",
    "dev-check": "npm run type-check -- --incremental && npm run lint:fast -- --fix",
    "lint:fast": "eslint --cache --concurrency=auto",
    "type-check": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy --config dist/server/wrangler.json",
    "wrangler": "wrangler",
    "cf-typegen": "wrangler types",
    "postinstall": "npm run cf-typegen",
    "db:destroy": "rm -rf ./.wrangler/state/v3/d1",
    "db:migrate": "wrangler d1 migrations apply enhansome-registry --local",
    "db:migrate:remote": "wrangler d1 migrations apply enhansome-registry --remote",
    "db:shell": "wrangler d1 execute enhansome-registry --local",
    "db:shell:remote": "wrangler d1 execute enhansome-registry --remote",
    "knip": "knip"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/devtools-vite": "^0.5.3",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@tanstack/eslint-plugin-router": "^1.161.4",
    "@tanstack/react-devtools": "^0.9.10",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-router-devtools": "^1.166.2",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/react-virtual": "^3.13.21",
    "@tanstack/router-plugin": "^1.166.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "flexsearch": "^0.8.212",
    "globals": "^17.4.0",
    "jszip": "^3.10.1",
    "kysely": "^0.28.11",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.577.0",
    "pluralize-esm": "^9.0.5",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.12.20",
    "@cloudflare/workers-types": "^4.20260307.1",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^9.39.4",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.71.0"
  }
}
